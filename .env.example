# =====================================================
# 운영 환경 변수 템플릿
# 이 파일을 복사하여 .env 파일 생성 후 실제 값 입력
#   cp .env.example .env
# =====================================================

# PostgreSQL
POSTGRES_DB=sagwim_db
POSTGRES_USER=sagwim_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis (비밀번호 없으면 빈 값)
REDIS_PASSWORD=

# JWT (최소 32자 이상의 랜덤 문자열)
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_SECRET

# Google Maps Geocoding API
GOOGLE_MAPS_API_KEY=

# 메일 설정 (Gmail App Password)
MAIL_USERNAME=
MAIL_PASSWORD=

# 이미지 URL (외부 접근 가능한 서버 주소)
IMAGE_URL_PREFIX=http://your-domain.com/images

# CORS 허용 출처 (운영 도메인 — 쉼표로 여러 개 지정 가능)
CORS_ALLOWED_ORIGINS=http://sagwim.duckdns.org

# Docker 이미지 태그 (배포 시 자동 설정됨)
BE_IMAGE_TAG=latest
FE_IMAGE_TAG=latest

# 소셜 로그인 (선택)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
